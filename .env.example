# Genymotion Cloud API Configuration
# Get your API key from: https://www.genymotion.com/enterprise/api/
# IMPORTANT: Never commit your actual API key to git!

GENYMOTION_API_KEY=your_api_key_here

# Android ADB MCP Configuration
ANDROID_ADB_HOST=localhost
ANDROID_ADB_PORT=5037
ANDROID_ADB_ALLOWED_COMMANDS=ls,cat,echo,pwd,whoami,date,pm,am,dumpsys,getprop,setprop,input,screencap,screenrecord,monkey,logcat,ps,top,df,du,find
